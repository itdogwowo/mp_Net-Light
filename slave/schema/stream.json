{
  "group": "stream",
  "cmds": [
    {
      "cmd": "0x3001",
      "name": "STREAM_INFO",
      "payload": [
        {"name": "total_blocks", "type": "u32"},
        {"name": "frames_per_block", "type": "u32"},
        {"name": "fps", "type": "u8"}
      ]
    },
    {
      "cmd": "0x3009",
      "name": "STREAM_STATE_SET",
      "payload": [
        {"name": "block_id", "type": "u32"},
        {"name": "frame_offset", "type": "u32"},
        {"name": "priority", "type": "u8"},
        {"name": "target_slot", "type": "u8"}
      ]
    },
    {
      "cmd": "0x3008",
      "name": "STREAM_READY_ACK",
      "payload": [
        {"name": "block_id", "type": "u32"},
        {"name": "frame_offset", "type": "u32"},
        {"name": "status", "type": "u8"},
        {"name": "slot", "type": "u8"},
        {"name": "replaced_block", "type": "i32"}
      ]
    },
    {
      "cmd": "0x300A",
      "name": "STREAM_PLAY",
      "payload": []
    },
    {
      "cmd": "0x3005",
      "name": "STREAM_PAUSE",
      "payload": [
        {"name": "pause", "type": "u8"}
      ]
    },
    {
      "cmd": "0x3002",
      "name": "STREAM_STOP",
      "payload": []
    },
    {
      "cmd": "0x3004",
      "name": "STREAM_SEEK",
      "payload": [
        {"name": "target_block", "type": "u32"},
        {"name": "target_frame", "type": "u32"}
      ]
    },
    {
      "cmd": "0x3012",
      "name": "STREAM_BLOCK_COMPLETE",
      "payload": [
        {"name": "block_id", "type": "u32"},
        {"name": "start_frame", "type": "u32"},
        {"name": "end_frame", "type": "u32"},
        {"name": "play_time_ms", "type": "u32"},
        {"name": "actual_fps", "type": "u16"},
        {"name": "next_block", "type": "u32"},
        {"name": "next_frame", "type": "u32"},
        {"name": "freed_slot", "type": "u8"},
        {"name": "interrupted", "type": "u8"}
      ]
    }
  ]
}